# Copia este archivo como .env y rellena los valores reales
# NUNCA subas el .env real a git o a Azure — usa App Settings en el portal

# Clave secreta para sesiones Flask (genera una con: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=cambia_esto_por_una_clave_larga_y_aleatoria

# Credenciales de correo Microsoft 365
MAIL_USERNAME=tu_correo@tudominio.com
MAIL_PASSWORD=tu_contraseña_o_app_password

# Modo debug (0 = producción, 1 = desarrollo local)
FLASK_DEBUG=0
